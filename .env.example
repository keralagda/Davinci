# ─── Database ─────────────────────────────────────────────────────────────────
# Local development (SQLite)
DATABASE_URL="file:./db/custom.db"

# Production (Turso - set these in Vercel Environment Variables)
TURSO_DATABASE_URL="libsql://your-database.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# ─── AI Providers ────────────────────────────────────────────────────────────
# NVIDIA NIM (primary for text/chat/code)
NVIDIA_API_KEY="nvapi-..."

# Cloudflare Workers AI (primary for images, fallback for text)
CLOUDFLARE_ACCOUNT_ID="your-account-id"
CLOUDFLARE_API_KEY="your-api-key"

# Bytez (fallback for text, TTS, STT)
BYTEZ_API_KEY="your-bytez-key"

# Groq (optional fast fallback)
GROQ_API_KEY="gsk_..."

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."

# ─── Optional ─────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=""
CEREBRAS_API_KEY=""
HUGGINGFACE_API_KEY=""
PEXELS_API_KEY=""
OPENROUTER_API_KEY=""
